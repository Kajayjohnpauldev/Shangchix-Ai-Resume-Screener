# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
#
# This project uses litellm — the LLM provider is chosen entirely by the
# LLM_MODEL string. Uncomment one block below and set the matching API key.
# litellm picks up the key from the environment automatically; no code change.

# --- Groq (default — free, very fast, no billing) ---
#   Get a key (free): https://console.groq.com/keys
LLM_MODEL=groq/llama-3.1-8b-instant
GROQ_API_KEY=your_groq_api_key_here

# --- Google Gemini (free tier — needs free-tier quota enabled on the key) ---
#   Get a key: https://aistudio.google.com/apikey
# LLM_MODEL=gemini/gemini-2.0-flash
# GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenAI ---
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your_openai_api_key_here

# Server config
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Scoring config
TOP_K_EXPLAIN=5          # Top candidates to generate explanations for
LLM_TIMEOUT_SECONDS=15
