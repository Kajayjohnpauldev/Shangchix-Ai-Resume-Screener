# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
#
# This project uses LangChain to talk to the LLM. Pick a provider with
# LLM_PROVIDER and supply the matching API key.
#
# Default: OpenAI (gpt-4o-mini). Free alternative: Gemini.
#   Get an OpenAI key:  https://platform.openai.com/api-keys
#   Get a Gemini key:   https://aistudio.google.com/apikey   (free tier)

# --- OpenAI (default) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here

# --- Gemini (free alternative) ---
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-flash
# GEMINI_API_KEY=your_gemini_api_key_here

# Server config
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Scoring config
TOP_K_EXPLAIN=5          # Top candidates to generate explanations for
LLM_TIMEOUT_SECONDS=15
